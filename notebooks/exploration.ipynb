    "## 6. Quick probe: logistic regression at each layer\n",
    "\n",
    "Let's fit a simple logistic regression at each layer and see if the accuracy goes up in later layers.\n",
    "\n",
    "This is a rough version of what `src/experiments/run_probe_sweep.py` does properly (with cross-validation, etc.). Here I just want a quick picture to decide if this is even worth pursuing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import StratifiedKFold\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "# quick 5-fold CV logistic regression at each layer\n",
    "# using C=1.0 (default) — will tune in the real sweep\n",
    "\n",
    "n_folds = 5\n",
    "skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=SEED)\n",
    "\n",
    "layer_accs = []\n",
    "layer_accs_std = []\n",
    "\n",
    "for layer_idx in range(n_layers):\n",
    "    reps = all_layer_reps[:, layer_idx, :]  # [n_examples, d_model]\n",
    "    \n",
    "    fold_accs = []\n",
    "    for train_idx, val_idx in skf.split(reps, labels):\n",
    "        X_train, X_val = reps[train_idx], reps[val_idx]\n",
    "        y_train, y_val = labels[train_idx], labels[val_idx]\n",
    "        \n",
    "        # normalize features\n",
    "        scaler = StandardScaler()\n",
    "        X_train_scaled = scaler.fit_transform(X_train)\n",
    "        X_val_scaled = scaler.transform(X_val)\n",
    "        \n",
    "        clf = LogisticRegression(\n",
    "            C=1.0,\n",
    "            max_iter=1000,\n",
    "            random_state=SEED,\n",
    "            solver='lbfgs',\n",
    "        )\n",
    "        clf.fit(X_train_scaled, y_train)\n",
    "        preds = clf.predict(X_val_scaled)\n",
    "        fold_accs.append(accuracy_score(y_val, preds))\n",
    "    \n",
    "    layer_accs.append(np.mean(fold_accs))\n",
    "    layer_accs_std.append(np.std(fold_accs))\n",
    "\n",
    "layer_accs = np.array(layer_accs)\n",
    "layer_accs_std = np.array(layer_accs_std)\n",
    "\n",
    "print('layer-by-layer probe accuracy (5-fold CV):')\n",
    "for i, (acc, std) in enumerate(zip(layer_accs, layer_accs_std)):\n",
    "    bar = '#' * int(acc * 40)\n",
    "    print(f'  layer {i:2d}: {acc:.3f} ± {std:.3f}  {bar}')\n",
    "\n",
    "print(f'\\nbest layer: {layer_accs.argmax()} (acc={layer_accs.max():.3f})')\n",
    "print(f'chance: {max(labels.mean(), 1-labels.mean()):.3f}')"
   ]
