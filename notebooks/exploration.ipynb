   "source": [
    "## 4. Extract activations for the full dataset\n",
    "\n",
    "Now do this for all examples. This will take a few minutes on CPU.\n",
    "\n",
    "Strategy: for each (prompt, completion) pair, concatenate them, run through model, extract the last-token residual stream at each layer. That gives us a [n_layers, d_model] matrix per example, which we'll store as a [n_examples, n_layers, d_model] tensor.\n",
    "\n",
    "NOTE: I'm using the last token of the *full prompt+completion* as my representation. Alternative would be to use the last token of just the prompt — but that loses information about *how the model is completing* the sequence. Will think about this more."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from tqdm.notebook import tqdm\n",
    "\n",
    "# limit to a manageable subset for exploration\n",
    "# full sweep will use all data — see src/experiments/run_probe_sweep.py\n",
    "MAX_EXAMPLES = 200  # TODO: increase this once I've confirmed the pipeline works\n",
    "\n",
    "subset = dataset.data[:MAX_EXAMPLES]\n",
    "labels = np.array([ex['label'] for ex in subset])\n",
    "\n",
    "print(f'using {len(subset)} examples ({labels.sum()} syco, {(1-labels).sum()} non-syco)')\n",
    "\n",
    "all_layer_reps = []  # will be [n_examples, n_layers, d_model]\n",
    "\n",
    "for ex in tqdm(subset, desc='extracting activations'):\n",
    "    text = ex['prompt'] + ex['completion']\n",
    "    tokens = model.to_tokens(text)\n",
    "    \n",
    "    # truncate if too long — TransformerLens can OOM on very long sequences\n",
    "    # Pythia-1.4B has 2048 context window\n",
    "    if tokens.shape[1] > 512:  # conservative limit for exploration\n",
    "        tokens = tokens[:, :512]\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        _, cache = model.run_with_cache(\n",
    "            tokens,\n",
    "            names_filter=lambda name: name.endswith('hook_resid_post'),\n",
    "        )\n",
    "    \n",
    "    # extract last-token rep at each layer\n",
    "    ex_reps = []\n",
    "    for layer_idx in range(n_layers):\n",
    "        key = f'blocks.{layer_idx}.hook_resid_post'\n",
    "        rep = cache[key][0, -1, :].cpu().float().numpy()  # float() in case of bf16\n",
    "        ex_reps.append(rep)\n",
    "    \n",
    "    all_layer_reps.append(np.stack(ex_reps))  # [n_layers, d_model]\n",
    "    \n",
    "    # free cache\n",
    "    del cache\n",
    "\n",
    "all_layer_reps = np.stack(all_layer_reps)  # [n_examples, n_layers, d_model]\n",
    "print(f'activations shape: {all_layer_reps.shape}')"
   ]
