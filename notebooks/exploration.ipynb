    "print()\n",
    "\n",
    "# run with cache — this gets ALL intermediate activations\n",
    "with torch.no_grad():\n",
    "    logits, cache = model.run_with_cache(\n",
    "        tokens,\n",
    "        names_filter=lambda name: name.endswith('hook_resid_post'),\n",
    "        # only cache resid_post to save memory\n",
    "        # could also do resid_pre, attn_out, mlp_out etc. later\n",
    "    )\n",
    "\n",
    "print('cache keys (resid_post):')\n",
    "resid_keys = [k for k in cache.keys() if 'resid_post' in k]\n",
    "for k in resid_keys:\n",
    "    print(f'  {k}: {cache[k].shape}')  # expect [1, seq_len, d_model]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# extract the last-token residual stream for each layer\n",
    "# this is the representation that \"decides\" the next token\n",
    "\n",
    "layer_reps = []\n",
    "for layer_idx in range(n_layers):\n",
    "    key = f'blocks.{layer_idx}.hook_resid_post'\n",
    "    # shape: [1, seq_len, d_model] -> take last token -> [d_model]\n",
    "    rep = cache[key][0, -1, :].cpu().numpy()\n",
    "    layer_reps.append(rep)\n",
    "\n",
    "layer_reps = np.stack(layer_reps)  # [n_layers, d_model]\n",
    "print(f'layer_reps shape: {layer_reps.shape}')\n",
    "\n",
    "# sanity: norms should generally increase through layers\n",
    "norms = np.linalg.norm(layer_reps, axis=1)\n",
    "print(f'residual stream norms by layer:')\n",
    "print(norms.round(2))\n",
    "\n",
    "# NOTE: with fold_ln=True, norms might not show the clean monotone increase\n",
